{
  "name": "nur-monorepo",
  "private": true,
  "workspaces": [
    "apps/web",
    "packages/shared-types"
  ],
  "scripts": {
    "secret-scan": "bash infra/scripts/secret-scan.sh",
    "web:typecheck": "npm --workspace apps/web run typecheck",
    "web:test": "npm --workspace apps/web run test -- --run",
    "web:build": "npm --workspace apps/web run build",
    "v197:integrity": "bash infra/scripts/check-v197-integrity.sh",
    "web:e2e:mocked": "npm --workspace apps/web run e2e -- e2e/talk.spec.ts e2e/visual-readiness.spec.ts",
    "mobile:typecheck": "npm --prefix apps/mobile run typecheck"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^6.0.3",
    "vite": "^8.1.3"
  }
}
